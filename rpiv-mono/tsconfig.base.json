{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"noEmit": true,
		"types": ["node"],
		"baseUrl": ".",
		"paths": {
			"pi-subagents": ["packages/rpiv-pi/extensions/subagent-widget/pi-subagents-stubs/index.d.ts"],
			"pi-subagents/render": ["packages/rpiv-pi/extensions/subagent-widget/pi-subagents-stubs/render.d.ts"],
			"pi-subagents/agent-manager": ["packages/rpiv-pi/extensions/subagent-widget/pi-subagents-stubs/agent-manager.d.ts"]
		}
	},
	"include": ["packages/*/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
	"exclude": [
		"**/node_modules/**",
		"**/.pi/**",
		"**/.rpiv/**",
		"**/thoughts/**"
	]
}
